# Local dev (default): leave empty — browser calls /api, Vite proxies to localhost:5000
VITE_API_URL=

# Optional: hit API directly (e.g. phone on same network). Use your machine's current IPv4 from ipconfig.
# VITE_API_URL=http://192.168.1.45:5000

# Override proxy target only (when VITE_API_URL is empty):
# VITE_API_PROXY_TARGET=http://localhost:5000
